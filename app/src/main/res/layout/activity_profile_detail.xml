<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:fitsSystemWindows="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="16dp">

                <ImageView
                    android:id="@+id/backButton"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:padding="8dp"
                    android:src="@android:drawable/ic_menu_revert"
                    android:contentDescription="返回"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="个人资料"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_text_color" />

                <View
                    android:layout_width="32dp"
                    android:layout_height="32dp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowAvatar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:minHeight="64dp"
                android:padding="12dp"
                android:background="@drawable/bg_dialog_round_white"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="头像"
                    android:textSize="16sp"
                    android:textColor="@color/primary_text_color" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <ImageView
                    android:id="@+id/avatarValueImageView"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="12dp"
                    android:src="@drawable/ic_nav_profile"
                    android:contentDescription="用户头像" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text=">"
                    android:textSize="18sp"
                    android:textColor="@color/primary_text_color" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowUsername"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:minHeight="56dp"
                android:padding="12dp"
                android:background="@drawable/bg_dialog_round_white"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="用户名"
                    android:textSize="16sp"
                    android:textColor="@color/primary_text_color" />

                <TextView
                    android:id="@+id/usernameValueTextView"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="用户"
                    android:textSize="16sp"
                    android:textColor="@color/primary_text_color" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text=">"
                    android:textSize="18sp"
                    android:textColor="@color/primary_text_color" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowGender"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:minHeight="56dp"
                android:padding="12dp"
                android:background="@drawable/bg_dialog_round_white"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="性别"
                    android:textSize="16sp"
                    android:textColor="@color/primary_text_color" />

                <TextView
                    android:id="@+id/genderValueTextView"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="保密"
                    android:textSize="16sp"
                    android:textColor="@color/primary_text_color" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text=">"
                    android:textSize="18sp"
                    android:textColor="@color/primary_text_color" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowRegion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:minHeight="56dp"
                android:padding="12dp"
                android:background="@drawable/bg_dialog_round_white"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="地区"
                    android:textSize="16sp"
                    android:textColor="@color/primary_text_color" />

                <TextView
                    android:id="@+id/regionValueTextView"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="未设置"
                    android:textSize="16sp"
                    android:textColor="@color/primary_text_color" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text=">"
                    android:textSize="18sp"
                    android:textColor="@color/primary_text_color" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowBirthday"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:minHeight="56dp"
                android:padding="12dp"
                android:background="@drawable/bg_dialog_round_white"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="生日"
                    android:textSize="16sp"
                    android:textColor="@color/primary_text_color" />

                <TextView
                    android:id="@+id/birthdayValueTextView"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="未设置"
                    android:textSize="16sp"
                    android:textColor="@color/primary_text_color" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text=">"
                    android:textSize="18sp"
                    android:textColor="@color/primary_text_color" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowSocialAccount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:minHeight="56dp"
                android:padding="12dp"
                android:background="@drawable/bg_dialog_round_white"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="社交账号"
                    android:textSize="16sp"
                    android:textColor="@color/primary_text_color" />

                <TextView
                    android:id="@+id/socialAccountValueTextView"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="未绑定"
                    android:textSize="16sp"
                    android:textColor="@color/primary_text_color" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text=">"
                    android:textSize="18sp"
                    android:textColor="@color/primary_text_color" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:minHeight="56dp"
                android:padding="12dp"
                android:background="@drawable/bg_dialog_round_white"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="联系方式"
                    android:textSize="16sp"
                    android:textColor="@color/primary_text_color" />

                <TextView
                    android:id="@+id/emailValueTextView"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="未设置"
                    android:textSize="16sp"
                    android:textColor="@color/primary_text_color" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text=">"
                    android:textSize="18sp"
                    android:textColor="@color/primary_text_color" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowSignature"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:minHeight="56dp"
                android:padding="12dp"
                android:background="@drawable/bg_dialog_round_white"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="个性签名"
                    android:textSize="16sp"
                    android:textColor="@color/primary_text_color" />

                <TextView
                    android:id="@+id/signatureValueTextView"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="这个人很懒，还没有写签名"
                    android:textSize="16sp"
                    android:textColor="@color/primary_text_color" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text=">"
                    android:textSize="18sp"
                    android:textColor="@color/primary_text_color" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowQrCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:minHeight="56dp"
                android:padding="12dp"
                android:background="@drawable/bg_dialog_round_white"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="个人二维码"
                    android:textSize="16sp"
                    android:textColor="@color/primary_text_color" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="12dp"
                    android:src="@drawable/ic_qr_code"
                    android:contentDescription="查看个人二维码" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text=">"
                    android:textSize="18sp"
                    android:textColor="@color/primary_text_color" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="4dp"
                android:text="隐私设置"
                android:textSize="14sp"
                android:textColor="@color/secondary_text_color" />

            <LinearLayout
                android:id="@+id/rowPrivacyEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:minHeight="56dp"
                android:padding="12dp"
                android:background="@drawable/bg_dialog_round_white"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="允许他人查看联系方式"
                    android:textSize="16sp"
                    android:textColor="@color/primary_text_color" />

                <Switch
                    android:id="@+id/switchPrivacyEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <ProgressBar
        android:id="@+id/loadingIndicator"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

</FrameLayout>
