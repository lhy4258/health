<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:elevation="2dp"
        app:cardCornerRadius="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/textPlanDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:gravity="center"
                android:background="@drawable/bg_plan_date_rounded"
                android:textSize="14sp"
                android:textColor="@color/primary_text_color" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="每日计划预期时长（分钟）"
                android:textSize="14sp"
                android:textColor="@color/primary_text_color" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="步行"
                    android:textSize="14sp"
                    android:textColor="@color/primary_text_color" />

                <EditText
                    android:id="@+id/editMinutesWalk"
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:hint="0" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="跑步"
                    android:textSize="14sp"
                    android:textColor="@color/primary_text_color" />

                <EditText
                    android:id="@+id/editMinutesRun"
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:hint="0" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="骑行"
                    android:textSize="14sp"
                    android:textColor="@color/primary_text_color" />

                <EditText
                    android:id="@+id/editMinutesRide"
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:hint="0" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="健身"
                    android:textSize="14sp"
                    android:textColor="@color/primary_text_color" />

                <EditText
                    android:id="@+id/editMinutesFitness"
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:hint="0" />
            </LinearLayout>

            <EditText
                android:id="@+id/editPlanRemark"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="12dp"
                android:gravity="top"
                android:hint="备注（可选）"
                android:inputType="textMultiLine"
                android:textSize="14sp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</ScrollView>
